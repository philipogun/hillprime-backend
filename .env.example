# HillPrime API - environment

APP_ENV=development
PORT=8080

# Public URLs ---------------------------------------------------------
BASE_URL=http://localhost:8080
ADMIN_APP_URL=http://localhost:3000/admin

# Database ------------------------------------------------------------
# Any Postgres 14+ URL works. Examples:
#   Supabase (pooled):  postgres://postgres.xxx:PASS@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
#   Neon:               postgres://USER:PASS@ep-abc.eu-central-1.aws.neon.tech/db?sslmode=require
#   Fly Postgres:       postgres://USER:PASS@myapp-db.flycast:5432/db
#   Local Docker:       postgres://postgres:postgres@localhost:5432/hillprime?sslmode=disable
DATABASE_URL=

# Email (Resend) ------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=HillPrime <no-reply@hillprimeinnovations.com>
FOUNDER_EMAIL=founder@hillprimeinnovations.com

# Push (Telegram) ------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Security ------------------------------------------------------------
# openssl rand -hex 32
INTERNAL_HMAC_KEY=

# CORS ----------------------------------------------------------------
ALLOWED_ORIGINS=https://hillprimeinnovations.com,https://www.hillprimeinnovations.com,http://localhost:3000

# Tuning --------------------------------------------------------------
HOT_LEAD_THRESHOLD=60
